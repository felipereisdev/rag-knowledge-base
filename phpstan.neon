includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - app/
        - database/

    # Pest test calls are not understood by PHPStan without a dedicated plugin.
    # Tests run via Pest itself; static analysis covers application and database code.
    excludePaths:
        - tests/
